<h3>Reviews:</h3 >
<% @reviews.each do |review| %>
  <div>
    <p><%= review.content %></p>
    <%# <p>Rating: <%= review.rating %></p> %>
    <p>Rating: <%= "⭐" * review.rating %></p>
    <%# <% if current_user && current_user == review.user %> %>
